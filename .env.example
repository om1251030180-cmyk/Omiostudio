PORT=4000
NODE_ENV=production

# Company inbox (receives fallback notifications)
COMPANY_LEADER_EMAIL=you@yourdomain.com

# Database
MONGO_URI=mongodb://localhost:27017/omio_studio

# Auth
JWT_SECRET=replace-with-a-strong-secret

# Admin Seed Account
ADMIN_EMAIL=admin@omio.studio
ADMIN_PASS=admin123

# Email (pick one setup)
# Option A: Gmail App Password
GMAIL_USER=
GMAIL_APP_PASS=

# Option B: SMTP Provider (Brevo, Mailgun, SendGrid SMTP, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
MAIL_FROM=
