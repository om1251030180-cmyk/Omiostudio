# ════════════════════════════════════════════════════════════════════════
# SECURITY WARNING ⚠️
# ════════════════════════════════════════════════════════════════════════
# NEVER commit this file with actual credentials to GitHub!
# This file is a TEMPLATE ONLY - copy to .env and fill with REAL values
# .env is in .gitignore and will NOT be committed automatically
# Always review your .gitignore before committing code!
#
# If you EVER commit secrets by mistake:
# 1. Run: git rm --cached .env
# 2. Commit: git commit -m "Remove .env from tracking"
# 3. Rotate all exposed credentials immediately!
# ════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:4000

# Company inbox (receives fallback notifications)
COMPANY_LEADER_EMAIL=you@yourdomain.com

# ═══════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════
MONGO_URI=mongodb://localhost:27017/omio_studio
# MONGO_USER=your_mongo_username
# MONGO_PASSWORD=your_mongo_password

# ═══════════════════════════════════════════════════════
# SECURITY SECRETS (Generate strong random values!)
# ═══════════════════════════════════════════════════════
# Generate JWT_SECRET (run in Node):
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_32_byte_hex_string_here_minimum_64_characters

# Admin Seed Account (Change these in production!)
ADMIN_EMAIL=admin@omio.studio
ADMIN_PASS=admin123

# ═══════════════════════════════════════════════════════
# EMAIL CONFIGURATION (pick one setup - Gmail is simplest)
# ═══════════════════════════════════════════════════════

# Option A: Gmail App Password (RECOMMENDED - FREE)
# 1. Enable 2FA on Gmail account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Select "Mail" and "Windows Computer"
# 4. Get 16-char password (remove spaces)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx

# Option B: SMTP Provider (Brevo, Mailgun, SendGrid, Outlook, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
MAIL_FROM=

# ═══════════════════════════════════════════════════════
# SMS & WHATSAPP (Twilio - Free trial $15 credit)
# ═══════════════════════════════════════════════════════
# Sign up FREE at: https://www.twilio.com/console
# 
# Steps:
# 1. Create account (FREE, verify phone)
# 2. Go to Console Dashboard
# 3. Copy Account SID and Auth Token
# 4. Get trial phone number (for SMS)
# 5. Request WhatsApp access
#
# NOTE: Trial accounts only send to verified numbers!
# Verify your number at: https://www.twilio.com/console/phone-numbers/verified

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE=+1234567890
TWILIO_WHATSAPP=+1234567890
